# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Cloudflare R2 ──────────────────────────────────────────────────────────
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=soundhub

# ── Anthropic (caption generation) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── TikTok Content Posting API ─────────────────────────────────────────────
# Apply at: https://developers.tiktok.com
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ── Instagram Graph API ────────────────────────────────────────────────────
# Create app at: https://developers.facebook.com
# Requires Instagram Business account + connected Facebook Page
INSTAGRAM_ACCESS_TOKEN=your-long-lived-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-business-account-id

# ── YouTube Data API v3 ────────────────────────────────────────────────────
# Create project at: https://console.cloud.google.com
# Enable YouTube Data API v3, generate OAuth2 credentials
# YOUTUBE_CREDENTIALS_JSON is the full JSON object from OAuth2 flow
YOUTUBE_CREDENTIALS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","token_uri":"https://oauth2.googleapis.com/token"}

# ── App ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-vercel-app.vercel.app
MIN_SEED_ENG_THRESHOLD=0.05
SEED_GRACE_CYCLES=2
